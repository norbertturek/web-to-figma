{
  "manifest_version": 3,
  "name": "Web to Figma",
  "version": "0.7.2",
  "description": "Captures page elements with positions, SVGs, and viewport control for Figma.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Web to Figma"
  }
}
